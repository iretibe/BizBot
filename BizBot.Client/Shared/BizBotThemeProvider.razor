@using MudBlazor

<MudThemeProvider Theme="@BizBotTheme" />

<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

@* @ChildContent *@

@code {
    // [Parameter]
    // public RenderFragment? ChildContent { get; set; }

    private readonly MudTheme BizBotTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = Colors.Blue.Default,
            Secondary = Colors.DeepPurple.Accent2,
            Background = "#F5F7FA",
            Surface = "#FFFFFF"
        }
    };
}


