@page "/chat"
@attribute [Authorize]

@rendermode InteractiveServer

@using BizBot.Client.Enums
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@inject BizBot.Client.Services.ChatClientService _chatClient

<MudPaper Class="pa-4" Elevation="2">

    <MudText Typo="Typo.h5">Bot Preview</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
        Test how your BizBot responds to user questions.
    </MudText>

    <MudTextField @bind-Value="Message"
                  Placeholder="Ask something..."
                  Variant="Variant.Outlined"
                  FullWidth
                  Immediate />

    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               Class="mt-2"
               Disabled="@IsSending"
               OnClick="Send">
        @if (IsSending)
        {
            <MudProgressCircular Indeterminate Size="Size.Small" Class="me-2" />
        }
        Test Response
    </MudButton>

    @if (!string.IsNullOrWhiteSpace(Response))
    {
        <MudPaper Class="pa-3 mt-4">
            <MudText Typo="Typo.subtitle2">BizBot says:</MudText>
            <MudText Typo="Typo.body1">@Response</MudText>
        </MudPaper>
    }

</MudPaper>

@code {
    private string Message = "";
    private string? Response;
    private bool IsSending;

    async Task Send()
    {
        if (string.IsNullOrWhiteSpace(Message)) return;

        IsSending = true;
        Response = null;

        var result = await _chatClient.SendMessageAsync(
            tenantId: "tenant_123",
            message: Message,
            conversationId: null);

        Response = result?.Message;
        IsSending = false;
    }
}



