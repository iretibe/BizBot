@page "/subscriptions"
@attribute [Authorize]
@rendermode InteractiveServer

@using BizBot.Client.Services
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using System.Security.Claims

@inject SubscriptionClientService _subClient
@inject AuthenticationStateProvider _authProvider

<style>
    .plan-card {
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

        .plan-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
        }

        .plan-card.selected {
            border: 2px solid var(--mud-palette-primary);
            background-color: rgba(98, 0, 238, 0.05);
        }

    .plan-badge-wrapper {
        position: relative;
    }

    .most-popular-chip {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
    }
</style>

<MudContainer MaxWidth="MaxWidth.False" Class="mt-6">

    <MudPaper Elevation="2" Class="pa-6">

        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom>
            Choose a Subscription Plan
        </MudText>

        <!-- BILLING TOGGLE -->
        <MudStack Direction="Row"
                  AlignItems="AlignItems.Center"
                  JustifyContent="Justify.Center"
                  Spacing="2"
                  Class="mt-4 mb-8">

            <MudText Typo="Typo.subtitle2">Monthly</MudText>

            <MudSwitch T="bool"
                       @bind-Checked="IsYearly"
                       Color="Color.Primary" />

            <MudText Typo="Typo.subtitle2">Yearly</MudText>

            <MudChip T="string"
                     Color="Color.Success"
                     Size="Size.Small">
                Save 20%
            </MudChip>

        </MudStack>

        <!-- PLANS -->
        <MudRadioGroup T="string" @bind-Value="Plan" Required="true">

            <MudGrid>

                <!-- STARTER -->
                <MudItem xs="12" md="4">
                    <MudCard Class="@GetPlanClass("starter")"
                             Outlined="true"
                             Style="cursor:pointer; height:100%"
                             OnClick="@(() => SelectPlan("starter"))">

                        <MudCardContent>
                            <MudRadio T="string" Value="@("starter")" />
                            <MudText Typo="Typo.h6">Starter</MudText>
                            <MudText Color="Color.Secondary">
                                @($"{GetPrice(29):C0} / {BillingLabel}")
                            </MudText>
                            <MudText Typo="Typo.body2">
                                Ideal for small teams getting started
                            </MudText>
                        </MudCardContent>

                    </MudCard>
                </MudItem>

                <!-- PRO (MOST POPULAR) -->
                <MudItem xs="12" md="4">

                    <div class="plan-badge-wrapper">

                        <MudChip T="string"
                                 Color="Color.Primary"
                                 Size="Size.Small"
                                 Class="most-popular-chip">
                            Most Popular
                        </MudChip>

                        <MudCard Class="@GetPlanClass("pro")"
                                 Outlined="true"
                                 Style="cursor:pointer; height:100%"
                                 OnClick="@(() => SelectPlan("pro"))">

                            <MudCardContent>
                                <MudRadio T="string" Value="@("pro")" />
                                <MudText Typo="Typo.h6">Pro</MudText>
                                <MudText Color="Color.Secondary">
                                    @($"{GetPrice(99):C0} / {BillingLabel}")
                                </MudText>
                                <MudText Typo="Typo.body2">
                                    Best for growing businesses
                                </MudText>
                            </MudCardContent>

                        </MudCard>

                    </div>

                </MudItem>

                <!-- AGENCY -->
                <MudItem xs="12" md="4">
                    <MudCard Class="@GetPlanClass("agency")"
                             Outlined="true"
                             Style="cursor:pointer; height:100%"
                             OnClick="@(() => SelectPlan("agency"))">

                        <MudCardContent>
                            <MudRadio T="string" Value="@("agency")" />
                            <MudText Typo="Typo.h6">Agency</MudText>
                            <MudText Color="Color.Secondary">
                                @($"{GetPrice(299):C0} / {BillingLabel}")
                            </MudText>
                            <MudText Typo="Typo.body2">
                                White-label & multi-client support
                            </MudText>
                        </MudCardContent>

                    </MudCard>
                </MudItem>

            </MudGrid>

        </MudRadioGroup>

        <!-- BUSINESS DETAILS -->
        <MudTextField @bind-Value="Email"
                      Label="Business Email"
                      Variant="Variant.Outlined"
                      Required="true"
                      FullWidth="true"
                      Class="mt-8" />

        <MudTextField @bind-Value="BusinessName"
                      Label="Business Name"
                      Variant="Variant.Outlined"
                      Required="true"
                      FullWidth="true"
                      Class="mt-3" />

        <!-- SUBMIT -->
        <MudButton OnClick="Subscribe"
                   Disabled="@(!IsFormValid || IsProcessing)"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   Class="mt-5">

            @(!IsProcessing ? "Proceed to Payment" : "Processing…")

        </MudButton>

        <MudText Typo="Typo.caption" Align="Align.Center" Class="mt-2">
            Prices shown in USD. Final billing is in GHS based on exchange rate.
        </MudText>

        @if (!string.IsNullOrWhiteSpace(CheckoutUrl))
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                <MudLink Href="@CheckoutUrl" Target="_blank">
                    Continue to secure payment
                </MudLink>
            </MudAlert>
        }

    </MudPaper>

</MudContainer>

@code {
    private string Plan = "pro";
    private bool IsYearly = false;
    private string Email = "";
    private string BusinessName = "";
    private string CheckoutUrl = "";
    private bool IsProcessing = false;

    private string BillingLabel => IsYearly ? "year" : "month";

    protected override async Task OnInitializedAsync()
    {
        var auth = await _authProvider.GetAuthenticationStateAsync();
        Email = auth.User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    }

    private void SelectPlan(string plan) => Plan = plan;

    private string GetPlanClass(string plan)
        => Plan == plan ? "pa-4 plan-card selected" : "pa-4 plan-card";

    private decimal GetPrice(decimal monthly)
        => IsYearly ? monthly * 12 * 0.8m : monthly;

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(Plan) &&
        !string.IsNullOrWhiteSpace(Email) &&
        !string.IsNullOrWhiteSpace(BusinessName);

    private async Task Subscribe()
    {
        if (!IsFormValid || IsProcessing)
            return;

        IsProcessing = true;
        CheckoutUrl = "";

        try
        {
            var result = await _subClient.InitializeAsync(Plan, Email, BusinessName, IsYearly);

            if (result != null)
                CheckoutUrl = result.AuthorizationUrl;
        }
        finally
        {
            IsProcessing = false;
        }
    }
}



